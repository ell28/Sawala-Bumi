# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for file upload (Foto/Video). Create bucket "bookings-media" in Supabase Dashboard.
SUPABASE_SERVICE_ROLE_KEY=

# Google Calendar (Service Account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=

# Xendit QRIS (QR only)
# XENDIT_SECRET_KEY - also set in Supabase: supabase secrets set XENDIT_SECRET_KEY=xxx
XENDIT_SECRET_KEY=
# Webhook verification: set in Xendit Dashboard > Callbacks, same value here
XENDIT_WEBHOOK_TOKEN=

# Base URL for webhook callback. For local dev use ngrok (Xendit can't reach localhost)
# Supabase: supabase secrets set APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=
