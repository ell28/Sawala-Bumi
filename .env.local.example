# Google Calendar (Service Account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=

# Xendit (Track B)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# Base URL for redirects (success/failure). Default: http://localhost:3000
NEXT_PUBLIC_APP_URL=
